<Window x:Class="QuickPreview.Windows.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickPreview"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="CanResize"
        SizeToContent="WidthAndHeight"
        MinWidth="380"
        MinHeight="300"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#1E1E1E"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="6" Opacity="0.6"/>
        </Border.Effect>

        <Grid x:Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition x:Name="ContentRow" Height="Auto"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Barra de título (arrastrable) -->
            <Border Grid.Row="0"
                    Background="#272727"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    MouseLeftButtonUp="TitleBar_MouseUp"
                    MouseMove="TitleBar_MouseMove"
                    Cursor="SizeAll">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse Width="8" Height="8" Fill="#4C90F3" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TitleText"
                                   Text="QuickPreview"
                                   Foreground="#CCCCCC"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button Style="{StaticResource ActionBtn}"
                                Content="↗"
                                ToolTip="Abrir con programa predeterminado"
                                Click="OpenWithBtn_Click"/>
                        <Button Style="{StaticResource CloseBtn}"
                                Content="✕"
                                Click="CloseBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Área de contenido -->
            <Border Grid.Row="1" Background="#1A1A1A">
                <Grid>
                    <!-- Spinner visible mientras carga -->
                    <Border x:Name="LoadingPane" MinWidth="400" MinHeight="240">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True"
                                         Width="180" Height="2"
                                         Foreground="#4C90F3"
                                         Background="#2A2A2A"
                                         BorderThickness="0"/>
                            <TextBlock x:Name="LoadingText"
                                       Text="Cargando..."
                                       Foreground="#555555"
                                       FontSize="11"
                                       Margin="0,12,0,0"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    <!-- Contenido real (oculto hasta que cargue) -->
                    <ScrollViewer x:Name="ContentScroll"
                                  Visibility="Collapsed"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxWidth="960"
                                  MaxHeight="720">
                        <ContentControl x:Name="PreviewContent"
                                        Margin="16"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MinWidth="300"
                                        MinHeight="200"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Barra de estado -->
            <Border Grid.Row="2" Background="#242424" CornerRadius="0,0,10,10">
                <Grid Margin="14,0">
                    <TextBlock x:Name="FileInfoText"
                               Foreground="#666666"
                               FontSize="10"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="← → navegar  ·  F pantalla  ·  Esp / Esc cerrar"
                               Foreground="#909090"
                               FontSize="10"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
