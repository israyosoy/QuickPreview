<Window x:Class="QuickPreview.Windows.DocumentPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="QuickPreview"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#1E1E1E"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        ResizeMode="CanResize"
        Width="1020"
        Height="740"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4" Width="28" Height="28">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border gives 1px dark outline -->
    <Border BorderBrush="#3A3A3A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="#272727"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse Width="8" Height="8" Fill="#4C90F3" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TitleText"
                                   Foreground="#CCCCCC"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource FlatBtn}"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Content layer: loading overlay + WebView2 -->
            <Grid Grid.Row="1">
                <!-- WebView2 (hidden until content is ready) -->
                <wv2:WebView2 x:Name="WebView" Visibility="Collapsed"/>

                <!-- Loading overlay -->
                <Border x:Name="LoadingPane" Background="#1A1A1A">
                    <TextBlock x:Name="LoadingText"
                               Text="Cargando…"
                               Foreground="#555555"
                               FontSize="14"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#242424">
                <Grid Margin="14,0">
                    <TextBlock x:Name="FileInfoText"
                               Foreground="#666666"
                               FontSize="10"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="← → navegar  ·  Esc cerrar"
                               Foreground="#909090"
                               FontSize="10"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
